<% layout("/layouts/boilerplate") %>

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow-lg border-0 rounded-4 p-4">

                <!-- Profile Header -->
                <div class="text-center">

                    <div 
                        class="rounded-circle bg-dark text-white d-flex align-items-center justify-content-center mx-auto mb-3"
                        style="width:100px; height:100px; font-size:2rem;"
                    >
                        <%= currUser.username.split("@")[0].charAt(0).toUpperCase() %>
                    </div>

                    <h2 class="fw-bold">
                        <%= currUser.username.split('@')[0] %>
                    </h2>

                    <p class="text-muted">
                        gmail: <%= currUser.email %>
                    </p>

                </div>

                <hr>

                <!-- Account Info -->
                <div class="row text-center">

                    <div class="col-md-4 mb-3">
                        <h5 class="fw-bold">Joined</h5>

                        <p>
                            <%= currUser.createdAt 
                                ? currUser.createdAt.toDateString()
                                : "Recently" %>
                        </p>
                    </div>

                    <div class="col-md-4 mb-3">
                        <h5 class="fw-bold">Listings</h5>
                        <p>0</p>
                    </div>

                    <div class="col-md-4 mb-3">
                        <h5 class="fw-bold">Bookings</h5>
                        <p>0</p>
                    </div>

                </div>

                <hr>

                <!-- Future Section -->
                <div>

                    <h4 class="fw-bold mb-3">
                        Upcoming Trips
                    </h4>

                    <!-- Display Bookings -->
                    <div class="alert alert-info rounded-3">
                        <% if(bookings.length > 0){ %>

                            <div class="row">

                                <% bookings.forEach((booking) => { %>

                                    <div class="col-md-6 mb-4">

                                        <div class="card shadow-sm border-0 rounded-4">

                                            <img 
                                                src="<%= booking.listing.image.url %>"
                                                class="card-img-top"
                                                style="height:220px; object-fit:cover;"
                                            >

                                            <div class="card-body ms-3">

                                                <h5 class="fw-bold mt-3">
                                                    <%= booking.listing.title %>
                                                </h5>

                                                <p class="text-muted mb-1">
                                                    <%= booking.listing.location %>,
                                                    <%= booking.listing.country %>
                                                </p>

                                                <hr>

                                                <p>
                                                    <b>Check In:</b>
                                                    <%= booking.checkIn.toLocaleDateString("en-GB", {
                                                        day: "2-digit",
                                                        month: "short",
                                                        year: "numeric"
                                                    }) %>
                                                </p>

                                                <p>
                                                    <b>Check Out:</b>
                                                    <%= booking.checkOut.toLocaleDateString("en-GB", {
                                                        day: "2-digit",
                                                        month: "short",
                                                        year: "numeric"
                                                    }) %>
                                                </p>

                                                <p>
                                                    <b>Guests:</b>

                                                    <%= booking.guests %>
                                                </p>

                                                <p>
                                                    <b>Status:</b>

                                                    <span class="badge bg-success">
                                                        <%= booking.status %>
                                                    </span>
                                                </p>

                                            </div>

                                        </div>

                                    </div>

                                <% }) %>

                            </div>

                        <% } else { %>

                            <div class="alert alert-info rounded-3">

                                No bookings yet.

                            </div>

                        <% } %>
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>